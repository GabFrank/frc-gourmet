{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "include": [
    "src/app/database/**/*.ts"
  ],
  "exclude": [
    "src/app/database/migrations/**/*.spec.ts"
  ]
}
