{
  "name": "frc-gourmet",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Gastronomic software for restaurant management",
  "homepage": "https://github.com/GabFrank/frc-gourmet",
  "repository": {
    "type": "git",
    "url": "https://github.com/GabFrank/frc-gourmet.git"
  },
  "bugs": {
    "url": "https://github.com/GabFrank/frc-gourmet/issues"
  },
  "author": {
    "name": "FRC Sistemas Informaticos",
    "email": "frcsistemasinformaticos@gmail.com"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.17.0 <21"
  },
  "scripts": {
    "ng": "ng",
    "start": "npm-run-all -p electron:serve ng:serve",
    "build": "npm run electron:serve-tsc && ng build --base-href ./",
    "build:mobile": "ng build mobile",
    "build:dev": "npm run build -- -c dev && npm run build:mobile",
    "build:prod": "npm run build -- -c production && npm run build:mobile",
    "check": "npm run electron:serve-tsc && ng build --configuration production --base-href ./",
    "ng:serve": "ng serve --port 4201",
    "electron:serve-tsc": "tsc -p tsconfig.electron.json",
    "electron:serve": "wait-on http-get://localhost:4201/ && npm run electron:serve-tsc && electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:build": "npm run build:prod && electron-builder build",
    "electron:publish": "npm run build:prod && electron-builder build --publish always",
    "test": "ng test",
    "test:e2e": "npm run electron:serve-tsc && npx playwright test",
    "test:e2e:dev": "npm run electron:serve-tsc && npx playwright test",
    "lint": "ng lint",
    "release": "semantic-release",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/app/database/datasource.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/app/database/datasource.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/app/database/datasource.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/app/database/datasource.ts",
    "icons": "node scripts/generate-icons.js",
    "generate:mobile-api": "node scripts/generate-mobile-api-map.js",
    "prepare": "husky || true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "15.2.9",
    "@angular/cdk": "15.2.9",
    "@angular/common": "15.2.9",
    "@angular/compiler": "15.2.9",
    "@angular/core": "15.2.9",
    "@angular/forms": "15.2.9",
    "@angular/language-service": "15.2.9",
    "@angular/material": "^15.2.9",
    "@angular/platform-browser": "15.2.9",
    "@angular/platform-browser-dynamic": "15.2.9",
    "@angular/router": "15.2.9",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^6.7.1",
    "@fastify/rate-limit": "^7.6.0",
    "@fastify/static": "^6.12.0",
    "@napi-rs/canvas": "^1.0.0",
    "@types/uuid": "^9.0.7",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "electron-pos-printer": "^1.3.7",
    "electron-updater": "^6.1.8",
    "exceljs": "^4.4.0",
    "fastify": "4.10",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "ng2-charts": "^4.1.1",
    "ngx-currency": "^2.5.3",
    "node-thermal-printer": "^4.4.4",
    "nodemailer": "^6.10.1",
    "pdfjs-dist": "^3.11.174",
    "pdfmake": "^0.2.10",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.1",
    "sqlite3": "^5.1.6",
    "tslib": "^2.5.0",
    "typeorm": "^0.3.21",
    "uuid": "^9.0.1",
    "zone.js": "~0.12.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "15.0.0",
    "@angular-devkit/build-angular": "15.2.8",
    "@angular-eslint/builder": "15.2.1",
    "@angular-eslint/eslint-plugin": "15.2.1",
    "@angular-eslint/eslint-plugin-template": "15.2.1",
    "@angular-eslint/schematics": "15.2.1",
    "@angular-eslint/template-parser": "15.2.1",
    "@angular/cli": "15.2.8",
    "@angular/compiler-cli": "15.2.9",
    "@babel/plugin-syntax-import-attributes": "^7.26.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@ngx-translate/core": "14.0.0",
    "@ngx-translate/http-loader": "7.0.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/commit-analyzer": "^11.1.0",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/release-notes-generator": "^12.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/electron": "^1.6.12",
    "@types/jasmine": "4.3.1",
    "@types/jasminewd2": "2.0.10",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^18.16.9",
    "@types/nodemailer": "^6.4.24",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "5.48.2",
    "@typescript-eslint/parser": "5.48.2",
    "conventional-changelog-cli": "2.2.2",
    "copy-webpack-plugin": "^13.0.0",
    "electron": "^24.3.0",
    "electron-builder": "24.4.0",
    "electron-debug": "3.2.0",
    "electron-reloader": "1.2.3",
    "eslint": "^8.33.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jsdoc": "44.2.3",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "husky": "^9.1.6",
    "jasmine-core": "4.6.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.2",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-electron": "7.3.0",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.0.0",
    "node-polyfill-webpack-plugin": "2.0.1",
    "npm-run-all": "4.1.5",
    "playwright": "^1.58.2",
    "png-to-ico": "^3.0.1",
    "semantic-release": "^22.0.12",
    "ts-node": "10.9.1",
    "typescript": "~4.9.5",
    "wait-on": "7.0.1",
    "webdriver-manager": "12.1.9"
  },
  "build": {
    "appId": "com.frcgourmet.app",
    "productName": "FRC Gourmet",
    "copyright": "Copyright (c) ${author}",
    "directories": {
      "output": "release/",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "main.js.map",
      "preload.js",
      "preload.js.map",
      "electron/**/*.js",
      "electron/**/*.js.map",
      "src/app/database/**/*.js",
      "src/app/database/**/*.js.map",
      "src/app/shared/**/*.js",
      "src/app/shared/**/*.js.map",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**",
      "**/node_modules/keytar/**",
      "**/node_modules/@napi-rs/canvas/**",
      "dist/mobile/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "GabFrank",
        "repo": "frc-gourmet",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "FRC-Gourmet-Setup-${version}.${ext}",
      "publisherName": "FRC Sistemas Informaticos",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FRC Gourmet",
      "uninstallDisplayName": "FRC Gourmet ${version}",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "linux": {
      "category": "Office",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "FRC-Gourmet-${version}-${arch}.${ext}",
      "icon": "build/icons"
    }
  }
}
